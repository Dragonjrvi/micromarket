    {
      "name": "Modulo I - Inventario",
      "item": [
        {
          "name": "Listar categorias",
          "request": { "method": "GET", "url": "http://localhost:8080/api/v1/api/categories" }
        },
        {
          "name": "Obtener categoria por id",
          "request": { "method": "GET", "url": "http://localhost:8080/api/v1/api/categories/1" }
        },
        {
          "name": "Crear categoria",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"name\": \"Bebidas\" }" },
            "url": "http://localhost:8080/api/v1/api/categories"
          }
        },
        {
          "name": "Actualizar categoria",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"name\": \"Bebidas Actualizadas\" }" },
            "url": "http://localhost:8080/api/v1/api/categories/1"
          }
        },
        {
          "name": "Eliminar categoria",
          "request": { "method": "DELETE", "url": "http://localhost:8080/api/v1/api/categories/1" }
        },
        {
          "name": "Listar productos",
          "request": { "method": "GET", "url": "http://localhost:8080/api/v1/api/products" }
        },
        {
          "name": "Obtener producto por id",
          "request": { "method": "GET", "url": "http://localhost:8080/api/v1/api/products/1" }
        },
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"name\": \"Coca Cola\", \"barcode\": \"123456\", \"price\": 3000, \"stock\": 20, \"categoryId\": 1 }"
            },
            "url": "http://localhost:8080/api/v1/api/products"
          }
        },
        {
          "name": "Actualizar producto",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"name\": \"Coca Cola Zero\", \"barcode\": \"123456\", \"price\": 3200, \"stock\": 25, \"categoryId\": 1 }"
            },
            "url": "http://localhost:8080/api/v1/api/products/1"
          }
        },
        {
          "name": "Eliminar producto (Soft Delete)",
          "request": { "method": "DELETE", "url": "http://localhost:8080/api/v1/api/products/1" }
        }
      ]
